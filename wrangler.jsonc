{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bouquetbuilder",
  "compatibility_date": "2026-04-04",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "frontend/dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "build": {
    "command": "cd frontend && npm install --legacy-peer-deps && VITE_API_URL=https://bouquetbuilder.onrender.com VITE_CHATBOT_URL=https://bouquetbuilder-chatbot.onrender.com npm run build"
  }
}
