{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bouquetbuilder",
  "compatibility_date": "2026-04-04",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "frontend/dist",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
